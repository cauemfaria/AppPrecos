# Copy this file to .env and fill in real values. NEVER commit .env.
# All variables below are read by supabase_client.py / app.py at startup.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in your Supabase dashboard → Project Settings → API.
SUPABASE_URL=https://your-project.supabase.co

# The service-role key bypasses Row Level Security. Treat it like a database
# password — never expose it to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-secret-service-role-key

# Optional: anon (public) key. Currently unused by the backend but reserved
# in case any future endpoint needs the user-facing key.
SUPABASE_ANON_KEY=your-anon-key

# ─── Bluesoft Cosmos (product enrichment) ────────────────────────────────────
# Comma-separated list of tokens. The worker rotates through them on 429.
COSMOS_TOKENS=token1,token2,token3
COSMOS_USER_AGENT=Cosmos-API-Request

# ─── Flask / CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, e.g. https://app.example.com,https://worker.example.com
# If unset in production a warning is printed and CORS falls back to "*".
CORS_ALLOWED_ORIGINS=

# "development" or "production". Affects CORS-fallback warning + Flask debug.
FLASK_ENV=development

# Port for Gunicorn / Flask dev server (defaults: gunicorn 10000, dev 5000).
PORT=5000
